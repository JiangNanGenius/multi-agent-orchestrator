# Multi-Agent Orchestrator - Hermes Agent environment template
# Copy to ~/.hermes/.env and fill only the values you actually use.

# LLM providers
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
GEMINI_API_KEY=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_ALLOWED_ROLES=

# Telegram
TELEGRAM_BOT_TOKEN=

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Slack
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# Optional runtime defaults
HERMES_DEFAULT_MODEL=
HERMES_PROVIDER=
